# --- LLM ---
OPENAI_API_KEY=your_openai_api_key_here

# --- MCP server URLs (how the FastAPI backend / agents reach them) ---
# Local development defaults (matches mcp_servers/*.py defaults):
HOTEL_MCP_URL=http://127.0.0.1:8001/mcp
FLIGHT_MCP_URL=http://127.0.0.1:8002/mcp
# When deployed, point these at your deployed MCP server URLs, e.g.:
# HOTEL_MCP_URL=https://tripweaver-hotel-mcp.onrender.com/mcp
# FLIGHT_MCP_URL=https://tripweaver-flight-mcp.onrender.com/mcp

# --- Upstream travel data API used by the MCP servers themselves ---
# (Only read by mcp_servers/hotel_server.py and mcp_servers/flight_server.py)
HOTEL_API_BASE=https://standing-fish-574.convex.site/hotels
FLIGHT_API_BASE=https://standing-fish-574.convex.site/flights

# --- Frontend ---
# Point the Gradio frontend at your deployed backend's streaming endpoint.
TRAVEL_PLANNER_API_URL=http://127.0.0.1:8000/chat/stream
